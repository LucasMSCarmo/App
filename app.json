{
  "expo": {
    "name": "AGENDINHA",
    "slug": "AGENDINHA",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "agendinha",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lucas-martins.AGENDINHA"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "jsEngine": "hermes",
      "package": "com.lucas_martins.AGENDINHA"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "@morrowdigital/watermelondb-expo-plugin",
        {
          "jsi": false
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
